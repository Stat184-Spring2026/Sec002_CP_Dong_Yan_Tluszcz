#The gender comparison shows that male-householder households earned more than female-householder households in both 2023 and 2024. Although median income remained higher for men, female-householder households experienced income growth between the two years while male-householder households experienced a slight decline.

#As a result, the female-to-male income ratio improved in 2024, indicating that the gender income gap narrowed slightly. Despite this improvement, the gap remains substantial, with female-householder households continuing to earn considerably less than male-householder households overall.

gender_df <- data.frame(
  group = c("Male Householder", "Female Householder"),
  income_2023 = c(58680, 43230),
  income_2024 = c(58000, 44870),
  moe_2024 = c(1866, 1256)
)

# Calculate ratios (female / male)
ratio_2023 <- gender_df$income_2023[2] / gender_df$income_2023[1]
ratio_2024 <- gender_df$income_2024[2] / gender_df$income_2024[1]

gender_analysis <- data.frame(
  ratio_2023 = ratio_2023,
  ratio_2024 = ratio_2024,
  improvement = ratio_2024 - ratio_2023,
  status = ifelse(ratio_2024 > ratio_2023, "Gap Narrowing", "Gap Widening")
)

cat("\n--- Gender Income Ratio (Female / Male) ---\n")
print(gender_analysis)

# Prepare gender plot
plot_gender <- pivot_longer(
  gender_df,
  cols = c("income_2023", "income_2024"),
  names_to = "Year",
  values_to = "Income"
)

plot_gender$Year <- ifelse(plot_gender$Year == "income_2023", "2023", "2024")

ggplot(plot_gender, aes(x = group, y = Income, fill = Year)) +
  geom_bar(stat = "identity", position = "dodge") +
  geom_text(aes(label = dollar(Income)), position = position_dodge(0.9), vjust = -0.5) +
  labs(
    title = "Median Income by Gender",
    subtitle = "Comparison of 2023 vs 2024",
    x = "Gender",
    y = "Income (USD)"
  ) +
  theme_minimal()
